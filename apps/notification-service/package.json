{
  "name": "@bytz/notification-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bytz/config": "workspace:*",
    "@bytz/db": "workspace:*",
    "@bytz/logger": "workspace:*",
    "@bytz/shared": "workspace:*",
    "@bytz/nats-events": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.0",
    "uuidv7": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
