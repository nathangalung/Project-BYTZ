{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@bytz/shared": ["./packages/shared/src/index.ts"],
      "@bytz/db": ["./packages/db/src/index.ts"],
      "@bytz/logger": ["./packages/logger/src/index.ts"],
      "@bytz/config": ["./packages/config/src/index.ts"],
      "@bytz/nats-events": ["./packages/nats-events/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "apps/ai-service"]
}
